[Unit]
Description=Alpaca Paper 0DTE Level 2 Engine
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=alpaca
Group=alpaca
WorkingDirectory=/home/alpaca/Alpaca-Trading
EnvironmentFile=/opt/alpaca-investing/secrets/alpaca.env
Environment=PATH=/usr/bin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
Environment=NODE_ENV=production
Environment=AUTOMATED_PAPER_EXECUTION_ENABLED=true
ExecStart=/usr/bin/npm run paper:monitor -- --task=zero-dte-engine
TimeoutStartSec=300
SyslogIdentifier=alpaca-zero-dte-engine
StandardOutput=journal
StandardError=journal
