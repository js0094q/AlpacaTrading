[Unit]
Description=Alpaca Autonomous Paper Worker
After=network-online.target alpaca-dashboard-control.service
Wants=network-online.target
StartLimitIntervalSec=300
StartLimitBurst=3

[Service]
Type=simple
User=alpaca
Group=alpaca
WorkingDirectory=/home/alpaca/Alpaca-Trading
EnvironmentFile=/opt/alpaca-investing/secrets/alpaca.env
Environment=PATH=/usr/bin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
Environment=NODE_ENV=production
Environment=TRADING_MODE=paper
Environment=ALPACA_ENV=paper
Environment=ALPACA_LIVE_TRADE=false
Environment=LIVE_TRADING_ENABLED=false
Environment=AUTOMATED_PAPER_EXECUTION_ENABLED=true
Environment=AUTONOMOUS_RUNTIME_AUDIT_APPROVED=true
Environment=DATABASE_BACKEND=postgres
Environment=POSTGRES_READS_ENABLED=true
Environment=POSTGRES_WRITES_ENABLED=true
Environment=POSTGRES_CONTROL_PLANE_AUTHORITY_ENABLED=true
Environment=POSTGRES_SCHEDULER_AUTHORITY_ENABLED=true
Environment=POSTGRES_EXECUTION_STATE_AUTHORITY_ENABLED=true
Environment=POSTGRES_SHADOW_COMPARE_ENABLED=false
Environment=POSTGRES_EXECUTION_STATE_SHADOW_ENABLED=false
Environment=SQLITE_AUDIT_MIRROR_ENABLED=false
ExecStart=/usr/bin/node scripts/autonomous-paper-worker.mjs --workstream-timeout-ms=3600000
Restart=on-failure
RestartSec=30
TimeoutStopSec=30
KillMode=mixed
NoNewPrivileges=true
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
